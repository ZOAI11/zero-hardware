[Unit]
Description=ZoarkBot Edge Server
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/zoark-edge-server
ExecStart=/usr/local/bin/uvicorn server:app --host 0.0.0.0 --port 8765 --workers 1
Restart=always
RestartSec=3
Environment=ZOARK_TTS_ENGINE=edge-tts

[Install]
WantedBy=multi-user.target
